<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="API TestSuite" thread-count="2" parallel="true">
	
	<listeners>
		<listener class-name="utils.ExtentReporter" />
	</listeners>
	
  <test name="Product">
    <classes>
      <class name="testcases.ProductTests"/>
    </classes>
  </test>
  
  <test name="User">
  	<classes>
  		<class name="testcases.UserTests"></class>
  	</classes>
  </test> 
  
  <test name="Cart">
  	<classes>
  		<class name="testcases.CartTests"></class>
  	</classes>
  </test>

  <test name="Authentication">
  	<classes>
  		<class name="testcases.Authentication"></class>
  	</classes>
  </test>
  
  <test name="Schema Validation">
  	<classes>
  		<class name="testcases.SchemaTests"></class>
  	</classes>
  </test>

</suite>